# 公開時に必要な設定。すべて無料サービスで充足可能。

# Vercel (デプロイ時に自動付与)
# NEXT_PUBLIC_URL=https://agora-network.vercel.app

# Resend - メール送信（無料 100通/日）
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=AGORA <hello@yourdomain.com>

# Neon - PostgreSQL（無料 0.5GB）
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# 待機リスト保存先（DB未設定なら console.log にフォールバック）
# 上記いずれも空でも、ローカル起動・Vercel無料デプロイは可能。
